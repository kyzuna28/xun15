# 
# KYZUNA SILENTSPEED CONFIG
#

# --- CORE IDENTITY ---
CONFIG_LOCALVERSION="-Kyzuna"
CONFIG_LIMITLESS=y
CONFIG_KSU=y
CONFIG_KSU_SUCOMPAT=y
CONFIG_KSU_MANUAL_HOOK=y

# --- FILESYSTEM & ENCRYPTION ---
CONFIG_FS_ENCRYPTION=y
CONFIG_FS_ENCRYPTION_ALGS=y
CONFIG_FS_ENCRYPTION_INLINE_CRYPT=y
CONFIG_F2FS_FS_ENCRYPTION=y
CONFIG_EXT4_ENCRYPTION=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_F2FS_FS_POSIX_ACL=y

# --- CRYPTO ALGORITHMS ---
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_XTS=y
CONFIG_CRYPTO_AES_ARM64=y
CONFIG_CRYPTO_AES_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
CONFIG_CRYPTO_AES_ARM64_NEON_BLK=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_CHACHA20=y
CONFIG_CRYPTO_GCM=y
CONFIG_CRYPTO_GHASH_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_CCM=y

# --- SYSTEM CORE ---
CONFIG_FUTEX=y
CONFIG_EVENTFD=y

# --- ZRAM & MEMORY ---
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_CRYPTO_DEFLATE=y
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZ4HC=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_ZSMALLOC=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CPUSETS=y
CONFIG_BLK_WBT=y

# --- HARDWARE & TOUCHSCREEN ---
CONFIG_FINGERPRINT_FPC_TEE=y
CONFIG_FINGERPRINT_GOODIX_TA=y
CONFIG_LEDS_LM3644=y
CONFIG_MACH_XIAOMI=y
CONFIG_MACH_XIAOMI_E10=y
CONFIG_MACH_XIAOMI_SDM845=y
CONFIG_TOUCHSCREEN_FTS=y
CONFIG_TOUCHSCREEN_NT36XXX=y
CONFIG_USE_BU64748=y
# CONFIG_FINGERPRINT_FPC_SCREEN_NOTIFY is not set
CONFIG_TOUCHSCREEN_FTS_DIRECTORY="focaltech_touch"
# CONFIG_TOUCHSCREEN_NT36XXX_ESD_PROTECT is not set
# CONFIG_TOUCHSCREEN_NT36XXX_MP_CTRLRAM is not set

# --- AUDIO & SOUND CONTROL ---
CONFIG_SND_SOC_WCD934X_MBHC=y
CONFIG_SND_SOC_MSM_DIRAC=y
CONFIG_VIBRATOR_VDD_OVERRIDE=y
CONFIG_SOUND_CONTROL=y
CONFIG_SND_SOC_MSM_QDSP6V2=y
CONFIG_AUDIO_EXT_CLK=y

# --- BATTERY & CHARGING ---
CONFIG_USB_FASTCHARGE=y
CONFIG_SMB1355_SLAVE_CHARGER=y
CONFIG_QPNP_SMB2=y
CONFIG_QTI_BATTERY_CHARGER=y
CONFIG_CHARGER_INPUT_LIMIT=y

# --- RCU & PREEMPTION ---
CONFIG_PREEMPT=y
CONFIG_RCU_EXPERT=y
CONFIG_RCU_FAST_NO_HZ=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_RCU_BOOST=y

# --- CPU GOVERNOR & WALT ---
CONFIG_HZ_300=y
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y
CONFIG_DEVFREQ_GOV_MEMLAT=y
CONFIG_SCHED_TUNE=y
CONFIG_SCHEDUTIL_TUNE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_BOOST=y
CONFIG_INPUT_BOOST=y
CONFIG_SCHED_WALT=y
CONFIG_WALT_SUGOV=y

# --- PERFORMANCE & TOUCH RESPONSE ---
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_EGRESS=y
CONFIG_NET_INGRESS=y

# --- ENTROPY ---
CONFIG_RANDOM_TRUST_CPU=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_TPM=y
CONFIG_HW_RANDOM_MSM_LEGACY=y

# --- GPU / ADRENO & RENDERING ---
CONFIG_ADRENO_IDLER=y
CONFIG_ADRENO_ACD=y
CONFIG_ADRENO_PERF_BOOST=y
CONFIG_QCOM_KGSL=y
CONFIG_QCOM_KGSL_IOMMU=y
CONFIG_MSM_SDE_ROTATOR_EVTLOG=y

# --- THERMAL & VOLTAGE LIMIT UNLOCK ---
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_STEP_WISE=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_QCOM_SDM845_THERMAL=y
CONFIG_QCOM_TSENS=y
CONFIG_QCOM_EBI_ERP=y
CONFIG_MSM_BCL_PERIPHERAL_CTL=y

# --- NETWORK, TCP CONGESTION & LOW LATENCY ---
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_NET_SCH_FQ=y
CONFIG_WIREGUARD=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_NETFILTER_XT_TARGET_HL=y
CONFIG_NETFILTER_XT_MATCH_HL=y
CONFIG_NETFILTER_XT_TARGET_TTL=y
CONFIG_NETFILTER_XT_MATCH_TTL=y
CONFIG_TCP_CONG_BIC=y
CONFIG_TCP_CONG_HTCP=y
CONFIG_HELIUM_WLAN_UCONN=y

# --- MQ I/O SCHEDULERS & UNBLOCKER ---
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_MQ_IOSCHED_BFQ=y
CONFIG_SCHED_CORE_CTL=y
CONFIG_SCHED_CORE_ROTATE=y
CONFIG_UCLAMP_TASK=y
CONFIG_DEFAULT_USE_ENERGY_AWARE=y
CONFIG_SCHED_MC=y
CONFIG_IRQ_TIME_ACCOUNTING=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_PSI=y
CONFIG_RCU_NOCB_CPU_ALL=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_NO_HZ=y
CONFIG_BLK_DEV_THROTTLING=y
# CONFIG_DEBUG_BLK_CGROUP is not set

# --- SCREEN COLOR ---
CONFIG_KCAL_EQ=y
CONFIG_KLAPSE=y

# --- DEBLOAT & DEBUG REMOVAL ---
CONFIG_PANIC_TIMEOUT=5
CONFIG_LOG_BUF_SHIFT=18
# CONFIG_RELR is not set
# CONFIG_PANIC_ON_REFCOUNT_ERROR is not set
# CONFIG_SHADOW_CALL_STACK is not set
# CONFIG_PANIC_ON_REBOOT is not set
# CONFIG_SCHEDSTATS is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_FTRACE is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_DEBUG_KMEMLEAK is not set
# CONFIG_DEBUG_PREEMPT is not set

# --- LTO & COMPILER ---
CONFIG_PERF_EVENTS=y
CONFIG_HW_PERF_EVENTS=y
# CONFIG_CC_WERROR is not set
# CONFIG_DEBUG_INFO is not set
CONFIG_DEBUG_INFO_NONE=y

# --- EXTRA FILESYSTEMS ---
CONFIG_EXFAT_FS=y
CONFIG_NTFS_FS=y
CONFIG_NTFS_RW=y
CONFIG_FUSE_FS=y
CONFIG_BLK_DEV_LOOP=y
